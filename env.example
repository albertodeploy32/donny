# Donny — Football Intelligence
# Copia questo file in ".env" e inserisci le tue chiavi
# Il file .env NON va mai committato su GitHub (già in .gitignore)

# OBBLIGATORIA — statistiche e fixture
# Chiave gratuita su: https://www.api-football.com (100 req/giorno)
API_FOOTBALL_KEY=la_tua_chiave_qui

# OPZIONALE ma consigliata — quote aggregate da più bookmaker EU
# Chiave gratuita su: https://the-odds-api.com (500 req/mese)
# Se assente, le quote vengono prese da API-Football (solo Bet365)
ODDS_API_KEY=la_tua_chiave_qui
